extends layout

block content
  .auth-container
    .auth-layout
      // Left Side - Branding
      .auth-side.side-brand
        .auth-branding
          .brand-icon 🚀
          h2.auth-title Error Handling Helpline
          p.auth-subtitle Join our community of developers and get help with your coding problems

        .auth-features
          .feature-item
            .feature-icon 💡
            .feature-text Connect with experienced developers
          .feature-item
            .feature-icon 📚
            .feature-text Share knowledge and learn together
          .feature-item
            .feature-icon 🏆
            .feature-text Build your reputation and skills

      // Right Side - Form
      .auth-side.side-form
        .auth-form
          h2.auth-title Create Your Account
          p.auth-subtitle Join thousands of developers helping each other

          if error
            .alert.alert-error
              span.alert-icon ⚠️
              span.alert-message= error
              button.alert-close(type="button") ✕

          form(method="POST" action="/sign-up")
            .auth-form-group
              label.form-label Username
              input.form-input(type="text" name="username" placeholder="Choose your username" required)
              p.form-hint Enter 3-20 characters (letters, numbers, underscores)

            .auth-form-group
              label.form-label Email
              input.form-input(type="email" name="email" placeholder="your@email.com" required)
              p.form-hint We'll use this to verify your account

            .auth-form-group
              label.form-label Password
              input.form-input(type="password" name="password" placeholder="Create a strong password" required)
              p.form-hint At least 8 characters with mixed case and numbers

            .auth-form-group
              .checkbox-group
                input.checkbox(type="checkbox" id="terms" name="terms" required)
                label.checkbox-label(for="terms")
                  | I agree to the
                  a.link(href="/terms") Terms of Service
                  | and
                  a.link(href="/privacy") Privacy Policy

            .auth-form-group
              .checkbox-group
                input.checkbox(type="checkbox" id="remember" name="remember")
                label.checkbox-label(for="remember") Remember me

            button.btn.btn-primary.btn-block(type="submit")
              | Create Account

          .auth-divider
            span or

          .auth-social
            a.auth-social-btn(href="/auth/github")
              | 🐙 GitHub
            a.auth-social-btn(href="/auth/google")
              | 🔍 Google

          .auth-footer
            | Already have an account?
            a(href="/login") Login here

          .auth-footer.forgot-password-link
            a(href="/forgot-password") Forgot your password?