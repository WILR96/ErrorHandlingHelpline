extends layout

block content
  .auth-container
    .auth-wrapper
      // Left Side - Branding
      .auth-side.auth-left
        .auth-branding
          .brand-icon 🚀
          h1.brand-title Error Handling Helpline
          p.brand-desc Join our community of developers and get help with your coding problems

        .auth-features
          .feature-item
            .feature-icon 💡
            .feature-text Connect with experienced developers
          .feature-item
            .feature-icon 📚
            .feature-text Share knowledge and learn together
          .feature-item
            .feature-icon 🏆
            .feature-text Build your reputation and skills

      // Right Side - Form
      .auth-side.auth-right
        .auth-card
          .auth-header
            h2.auth-title Create Your Account
            p.auth-subtitle Join thousands of developers helping each other

          if error
            .alert.alert-error
              span.alert-icon ⚠️
              span.alert-message= error
              button.alert-close(type="button") ✕

          form(method="POST" action="/sign-up").auth-form
            .form-group
              label.form-label Username
              input.form-input(type="text" name="username" placeholder="Choose your username" required)
              p.form-hint Enter 3-20 characters (letters, numbers, underscores)

            .form-group
              label.form-label Email
              input.form-input(type="email" name="email" placeholder="your@email.com" required)
              p.form-hint We'll use this to verify your account

            .form-group
              label.form-label Password
              input.form-input(type="password" name="password" placeholder="Create a strong password" required)
              p.form-hint At least 8 characters with mixed case and numbers

            .form-group
              .checkbox-group
                input.checkbox(type="checkbox" id="terms" required)
                label.checkbox-label(for="terms")
                  | I agree to the
                  a.link(href="#") Terms of Service
                  | and
                  a.link(href="#") Privacy Policy

            button.btn.btn-primary.btn-block(type="submit")
              | Create Account
              span.btn-icon →

          .auth-divider
            span or

          .auth-footer
            p.auth-text Already have an account?
              a.link.link-primary(href="/login") Login here

  style.
    .auth-container {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: calc(100vh - 80px);
      padding: 2rem;
      background: linear-gradient(135deg, #0f172a 0%, #1a1f3a 100%);
    }

    .auth-wrapper {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      max-width: 1000px;
      width: 100%;
      align-items: center;
    }

    .auth-side {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .auth-left {
      color: #cbd5e1;
    }

    .auth-branding {
      margin-bottom: 2rem;
    }

    .brand-icon {
      font-size: 3rem;
      margin-bottom: 1rem;
      display: block;
    }

    .brand-title {
      font-size: 2rem;
      font-weight: 800;
      margin-bottom: 0.5rem;
      background: linear-gradient(135deg, #38bdf8 0%, #0ea5e9 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .brand-desc {
      color: #94a3b8;
      line-height: 1.6;
    }

    .auth-features {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .feature-item {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
    }

    .feature-icon {
      font-size: 1.5rem;
      flex-shrink: 0;
    }

    .feature-text {
      color: #cbd5e1;
      line-height: 1.4;
    }

    .auth-right {
      display: flex;
      justify-content: center;
    }

    .auth-card {
      background: linear-gradient(135deg, #1e293b 0%, rgba(30, 41, 59, 0.5) 100%);
      border: 1px solid #334155;
      border-radius: 16px;
      padding: 2.5rem;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
      backdrop-filter: blur(10px);
    }

    .auth-header {
      margin-bottom: 2rem;
      text-align: center;
    }

    .auth-title {
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: #e2e8f0;
    }

    .auth-subtitle {
      color: #94a3b8;
      font-size: 0.95rem;
    }

    .alert {
      padding: 1rem;
      border-radius: 10px;
      display: flex;
      gap: 0.75rem;
      margin-bottom: 1.5rem;
      align-items: flex-start;
      animation: slideIn 0.3s ease;
    }

    .alert-error {
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.3);
      color: #fca5a5;
    }

    .alert-icon {
      font-size: 1.2rem;
      flex-shrink: 0;
    }

    .alert-message {
      flex: 1;
      line-height: 1.4;
    }

    .alert-close {
      background: none;
      border: none;
      color: #fca5a5;
      cursor: pointer;
      font-size: 1rem;
      padding: 0;
      transition: opacity 0.2s;
    }

    .alert-close:hover {
      opacity: 0.7;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(-10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .auth-form {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .form-label {
      font-weight: 600;
      color: #e2e8f0;
      font-size: 0.95rem;
    }

    .form-input {
      padding: 0.8rem 1rem;
      background: #0f172a;
      border: 2px solid #334155;
      color: #e2e8f0;
      border-radius: 8px;
      font-size: 1rem;
      transition: all 0.3s ease;
    }

    .form-input:focus {
      outline: none;
      border-color: #38bdf8;
      box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.1);
      background: #1e293b;
    }

    .form-input::placeholder {
      color: #64748b;
    }

    .form-hint {
      font-size: 0.8rem;
      color: #94a3b8;
      margin: 0;
    }

    .checkbox-group {
      display: flex;
      gap: 0.75rem;
      align-items: flex-start;
    }

    .checkbox {
      width: 20px;
      height: 20px;
      margin-top: 2px;
      cursor: pointer;
      accent-color: #38bdf8;
    }

    .checkbox-label {
      color: #cbd5e1;
      font-size: 0.9rem;
      line-height: 1.4;
      cursor: pointer;
    }

    .link {
      color: #38bdf8;
      text-decoration: none;
      transition: color 0.2s;
    }

    .link:hover {
      color: #0ea5e9;
      text-decoration: underline;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.9rem 1.5rem;
      border: none;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      font-size: 1rem;
      text-decoration: none;
    }

    .btn-primary {
      background: linear-gradient(135deg, #38bdf8 0%, #0ea5e9 100%);
      color: #0f172a;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(56, 189, 248, 0.4);
    }

    .btn-primary:active {
      transform: translateY(0);
    }

    .btn-block {
      width: 100%;
    }

    .btn-icon {
      font-size: 1.2rem;
    }

    .auth-divider {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin: 1.5rem 0;
      color: #475569;
    }

    .auth-divider::before,
    .auth-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #334155;
    }

    .auth-divider span {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .auth-footer {
      text-align: center;
    }

    .auth-text {
      color: #cbd5e1;
      margin: 0;
    }

    .link-primary {
      font-weight: 600;
      color: #38bdf8;
    }

    .link-primary:hover {
      color: #0ea5e9;
    }

    @media (max-width: 1024px) {
      .auth-wrapper {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .auth-left {
        display: none;
      }

      .auth-card {
        max-width: 100%;
      }
    }

    @media (max-width: 768px) {
      .auth-container {
        min-height: auto;
        padding: 1rem;
      }

      .auth-card {
        padding: 1.5rem;
      }

      .auth-title {
        font-size: 1.5rem;
      }

      .form-input {
        padding: 0.7rem 0.9rem;
      }

      .btn {
        padding: 0.8rem 1.2rem;
        font-size: 0.95rem;
      }
    }