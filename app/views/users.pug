extends layout

block content
  .breadcrumb
    a(href="/") Home
    span.breadcrumb-divider /
    span.breadcrumb-item.active Leaderboard

  .users-header
    h1.users-title 👥 Community Members
    p.users-subtitle Discover talented developers and connect with our community

  .container-sm
    // Search and Filter Bar
    .filter-bar
      .search-container
        span.search-icon 🔍
        input.search-input(type="text" placeholder="Search users by name..." id="userSearch" name="search" value=searchQuery || "")
      
      .filter-controls
        select.sort-button#sortBy(name="sort" onchange="applyFilters()")
          option(value="reputation" selected=sortBy === 'reputation') Sort by Reputation
          option(value="posts" selected=sortBy === 'posts') Sort by Posts
          option(value="recent" selected=sortBy === 'recent') Sort by Recent
          option(value="alpha" selected=sortBy === 'alpha') Sort A-Z
        
        button.filter-button.active(data-filter="all" onclick="filterUsers('all')")  All Users
        button.filter-button(data-filter="active" onclick="filterUsers('active')") Active Only
        button.filter-button(data-filter="helpers" onclick="filterUsers('helpers')") Top Helpers

    // Stats Overview
    .stats-grid
      .stat-card
        .stat-card-value= users.length || 0
        .stat-card-label Total Members
        .stat-card-change ↑ Growing community

      .stat-card
        .stat-card-value= activeCount || 0
        .stat-card-label Active This Week
        .stat-card-change ↑ High engagement

      .stat-card
        .stat-card-value= totalPosts || 0
        .stat-card-label Total Posts
        .stat-card-change ↑ Problem solving

      .stat-card
        .stat-card-value= totalAnswers || 0
        .stat-card-label Total Answers
        .stat-card-change ↑ Helpful answers

    // Users Grid
    .users-grid
      if users && users.length > 0
        each user, index in users
          .user-card
            .user-card-header
              .user-rank= index + 1
              if user.isActive
                .user-status.online
                  span.status-dot

            .user-avatar
              = (user.username || user.name || 'U').charAt(0).toUpperCase()

            .user-info
              h3.user-name
                a(href=`/users/${user.id}`)= user.username || user.name || 'User'
              p.user-title= user.title || 'Community Member'
              
              .user-stats
                .stat-item
                  span.stat-label Posts
                  span.stat-value= user.post_count || 0
                .stat-item
                  span.stat-label Answers
                  span.stat-value= user.answer_count || 0
                .stat-item
                  span.stat-label Reputation
                  span.stat-value= user.reputation || 0

            if user.skills
              .user-skills
                each skill in user.skills.split(',').slice(0, 3)
                  span.tag= skill.trim()

            .user-reputation
              .reputation-score= user.reputation || 0
              span.reputation-label Rep

            .user-actions
              a.action-btn(href=`/users/${user.id}` title="View Profile") 👁️
              button.action-btn(title="Send Message" onclick="sendMessage(" + user.id + ")") 💬
              button.action-btn(title="Follow" onclick="followUser(" + user.id + ")") ⭐

      else
        .empty-state
          .empty-state-icon 👥
          .empty-state-title No users found
          .empty-state-text Try adjusting your search filters

    // Pagination
    if totalPages && totalPages > 1
      .pagination
        if currentPage > 1
          a.page-link(href=`?page=${currentPage - 1}&sort=${sortBy || 'reputation'}&search=${searchQuery || ''}&filter=${activeFilter || 'all'}`) ← Previous
        
        - var startPage = Math.max(1, currentPage - 2);
        - var endPage = Math.min(totalPages, startPage + 4);
        
        if startPage > 1
          a.page-link(href="?page=1&sort=" + (sortBy || 'reputation')) 1
          if startPage > 2
            span.page-link ...
        
        - for (var i = startPage; i <= endPage; i++)
          if i === currentPage
            a.page-link.active(href=`?page=${i}`)= i
          else
            a.page-link(href=`?page=${i}&sort=${sortBy || 'reputation'}&search=${searchQuery || ''}&filter=${activeFilter || 'all'}`)= i
        
        if endPage < totalPages
          if endPage < totalPages - 1
            span.page-link ...
          a.page-link(href=`?page=${totalPages}&sort=${sortBy || 'reputation'}`)= totalPages
        
        if currentPage < totalPages
          a.page-link(href=`?page=${currentPage + 1}&sort=${sortBy || 'reputation'}&search=${searchQuery || ''}&filter=${activeFilter || 'all'}`) Next →

  script.
    const searchInput = document.getElementById('userSearch');
    let searchTimeout;

    searchInput.addEventListener('input', function() {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        applyFilters();
      }, 300);
    });

    function applyFilters() {
      const searchQuery = document.getElementById('userSearch').value;
      const sortBy = document.getElementById('sortBy').value;
      const filter = document.querySelector('.filter-button.active').getAttribute('data-filter');

      const params = new URLSearchParams({
        page: 1,
        search: searchQuery,
        sort: sortBy,
        filter: filter
      });

      window.location.href = `/leaderboards?${params.toString()}`;
    }

    function filterUsers(filter) {
      document.querySelectorAll('.filter-button').forEach(btn => {
        btn.classList.remove('active');
      });
      event.target.classList.add('active');
      applyFilters();
    }

    function sendMessage(userId) {
      alert('Message feature coming soon!');
    }

    function followUser(userId) {
      alert('Follow feature coming soon!');
    }