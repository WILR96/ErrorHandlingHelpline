extends layout

block content
  .breadcrumb
    a(href="/") Home
    span.breadcrumb-divider /
    span.breadcrumb-item.active Leaderboard

  .users-header
    h1.users-title 👥 Community Members
    p.users-subtitle Discover talented developers and connect with our community

  .container-sm
    // Search and Filter Bar
    .filter-bar
      .search-container
        span.search-icon 🔍
        input.search-input(type="text" placeholder="Search users by name, email, or skills..." id="userSearch")
      
      .filter-controls
        select.sort-button#sortBy
          option(value="reputation") Sort by Reputation
          option(value="posts") Sort by Posts
          option(value="recent") Sort by Recent
          option(value="alpha") Sort A-Z
        
        button.filter-button.active(data-filter="all") All Users
        button.filter-button(data-filter="active") Active Only
        button.filter-button(data-filter="helpers") Top Helpers

    // Stats Overview
    .stats-grid
      .stat-card
        .stat-card-value= users.length || 0
        .stat-card-label Total Members
        .stat-card-change ↑ Growing community

      .stat-card
        .stat-card-value 156
        .stat-card-label Active This Week
        .stat-card-change ↑ High engagement

      .stat-card
        .stat-card-value 2,847
        .stat-card-label Total Questions
        .stat-card-change ↑ Problem solving

      .stat-card
        .stat-card-value 8,392
        .stat-card-label Answers Given
        .stat-card-change ↑ Helpful answers

    // Users Grid
    .users-grid
      if users && users.length > 0
        each user, index in users
          .user-card
            .user-card-header
              .user-rank
                = index + 1
              .user-status.online
                span.status-dot

            .user-avatar
              = (user.username || user.name || 'U').charAt(0).toUpperCase()

            .user-info
              h3.user-name
                a(href=`/users/${user.id}`)= user.username || user.name || 'User'
              p.user-title Senior Developer
              
              .user-stats
                .stat-item
                  span.stat-label Questions
                  span.stat-value= Math.floor(Math.random() * 50) + 1
                .stat-item
                  span.stat-label Answers
                  span.stat-value= Math.floor(Math.random() * 100) + 1
                .stat-item
                  span.stat-label Reputation
                  span.stat-value= Math.floor(Math.random() * 5000) + 100

            .user-skills
              span.tag JavaScript
              span.tag Node.js
              span.tag React

            .user-reputation
              .reputation-score= Math.floor(Math.random() * 5000) + 100
              span.reputation-label Rep

            .user-actions
              button.action-btn(title="View Profile") 👁️
              button.action-btn(title="Send Message") 💬
              button.action-btn(title="Follow") ⭐

      else
        .empty-state
          .empty-state-icon 👥
          .empty-state-title No users found
          .empty-state-text Try adjusting your search filters

    // Pagination
    .pagination
      a.page-link ← Previous
      a.page-link.active 1
      a.page-link 2
      a.page-link 3
      span.page-link ...
      a.page-link 10
      a.page-link Next →

  style.
    .breadcrumb {
      margin-bottom: 1.5rem;
    }

    .users-header {
      background: linear-gradient(135deg, rgba(56, 189, 248, 0.1) 0%, rgba(14, 165, 233, 0.05) 100%);
      border-bottom: 2px solid #38bdf8;
      padding: 3rem 0;
      margin-bottom: 3rem;
      border-radius: 12px;
      box-shadow: 0 8px 32px rgba(56, 189, 248, 0.08);
      text-align: center;
    }

    .users-title {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
      background: linear-gradient(135deg, #38bdf8 0%, #0ea5e9 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .users-subtitle {
      color: #94a3b8;
      font-size: 1.1rem;
      margin: 0;
    }

    .container-sm {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .filter-bar {
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
      align-items: center;
      padding: 1.5rem;
      background: rgba(30, 41, 59, 0.5);
      border-radius: 10px;
      backdrop-filter: blur(10px);
      margin-bottom: 2rem;
      border: 1px solid #334155;
    }

    .search-container {
      display: flex;
      align-items: center;
      background: #1e293b;
      border: 2px solid #334155;
      border-radius: 10px;
      padding: 0.75rem 1rem;
      transition: all 0.3s ease;
      gap: 0.75rem;
      flex: 1;
      min-width: 250px;
    }

    .search-container:focus-within {
      border-color: #38bdf8;
      box-shadow: 0 0 20px rgba(56, 189, 248, 0.2);
    }

    .search-icon {
      color: #64748b;
      font-size: 1.2rem;
    }

    .search-input {
      border: none;
      background: transparent;
      color: #e2e8f0;
      font-size: 1rem;
      outline: none;
      width: 100%;
      padding: 0;
      margin: 0;
    }

    .search-input::placeholder {
      color: #64748b;
    }

    .filter-controls {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .sort-button,
    .filter-button {
      padding: 0.6rem 1.2rem;
      background: #334155;
      border: 1px solid #475569;
      color: #cbd5e1;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.3s ease;
      font-size: 0.9rem;
      font-weight: 500;
      white-space: nowrap;
    }

    .sort-button:hover,
    .filter-button:hover {
      background: #38bdf8;
      color: #0f172a;
      border-color: #0ea5e9;
      transform: translateY(-2px);
    }

    .filter-button.active {
      background: linear-gradient(135deg, #38bdf8 0%, #0ea5e9 100%);
      color: #0f172a;
      border-color: #38bdf8;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .stat-card {
      background: linear-gradient(135deg, rgba(56, 189, 248, 0.05) 0%, rgba(14, 165, 233, 0.02) 100%);
      border: 1px solid #334155;
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
      transition: all 0.3s ease;
      backdrop-filter: blur(10px);
    }

    .stat-card:hover {
      border-color: #38bdf8;
      transform: translateY(-6px);
      box-shadow: 0 10px 30px rgba(56, 189, 248, 0.15);
    }

    .stat-card-value {
      font-size: 2.5rem;
      font-weight: 800;
      background: linear-gradient(135deg, #38bdf8 0%, #0ea5e9 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 0.5rem;
    }

    .stat-card-label {
      font-size: 0.9rem;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 600;
    }

    .stat-card-change {
      font-size: 0.85rem;
      margin-top: 0.75rem;
      padding: 0.5rem;
      background: rgba(34, 197, 94, 0.1);
      border-radius: 6px;
      color: #86efac;
    }

    .users-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .user-card {
      background: linear-gradient(135deg, #1e293b 0%, rgba(30, 41, 59, 0.5) 100%);
      border: 1px solid #334155;
      border-radius: 12px;
      padding: 1.5rem;
      transition: all 0.3s ease;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      position: relative;
      overflow: hidden;
      backdrop-filter: blur(10px);
    }

    .user-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #38bdf8, #0ea5e9);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .user-card:hover {
      border-color: #38bdf8;
      box-shadow: 0 12px 35px rgba(56, 189, 248, 0.15);
      transform: translateY(-6px);
    }

    .user-card:hover::before {
      opacity: 1;
    }

    .user-card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
    }

    .user-rank {
      background: linear-gradient(135deg, #38bdf8 0%, #0ea5e9 100%);
      color: #0f172a;
      width: 32px;
      height: 32px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 0.9rem;
    }

    .user-status {
      position: relative;
    }

    .status-dot {
      width: 12px;
      height: 12px;
      background: #22c55e;
      border-radius: 50%;
      display: inline-block;
      border: 2px solid #0f172a;
      box-shadow: 0 0 0 2px #22c55e;
    }

    .user-card-content {
      display: flex;
      gap: 1rem;
    }

    .user-avatar {
      width: 80px;
      height: 80px;
      border-radius: 10px;
      background: linear-gradient(135deg, #38bdf8 0%, #0ea5e9 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      font-weight: bold;
      color: #0f172a;
      flex-shrink: 0;
      box-shadow: 0 4px 12px rgba(56, 189, 248, 0.3);
    }

    .user-info {
      flex: 1;
    }

    .user-name {
      font-size: 1.1rem;
      font-weight: 700;
      margin: 0 0 0.25rem 0;
      color: #e2e8f0;
    }

    .user-name a {
      color: #e2e8f0;
      text-decoration: none;
      transition: color 0.2s;
    }

    .user-name a:hover {
      color: #38bdf8;
    }

    .user-title {
      color: #94a3b8;
      font-size: 0.85rem;
      margin: 0 0 0.75rem 0;
    }

    .user-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
      padding: 0.75rem;
      background: rgba(56, 189, 248, 0.05);
      border-radius: 8px;
    }

    .stat-item {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      text-align: center;
    }

    .stat-label {
      font-size: 0.75rem;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }

    .stat-value {
      font-size: 1rem;
      font-weight: 700;
      color: #38bdf8;
    }

    .user-skills {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .tag {
      display: inline-block;
      padding: 0.3rem 0.7rem;
      background: rgba(56, 189, 248, 0.1);
      border: 1px solid rgba(56, 189, 248, 0.3);
      border-radius: 6px;
      color: #38bdf8;
      font-size: 0.75rem;
      font-weight: 500;
      transition: all 0.2s;
    }

    .tag:hover {
      background: rgba(56, 189, 248, 0.2);
      border-color: #38bdf8;
    }

    .user-reputation {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1rem;
      background: rgba(56, 189, 248, 0.05);
      border: 1px solid #334155;
      border-radius: 8px;
      justify-content: center;
    }

    .reputation-score {
      font-size: 1.5rem;
      font-weight: 800;
      color: #38bdf8;
    }

    .reputation-label {
      font-size: 0.8rem;
      color: #94a3b8;
      text-transform: uppercase;
    }

    .user-actions {
      display: flex;
      gap: 0.5rem;
      justify-content: center;
    }

    .action-btn {
      width: 36px;
      height: 36px;
      border-radius: 6px;
      border: 1px solid #334155;
      background: transparent;
      color: #cbd5e1;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
    }

    .action-btn:hover {
      background: rgba(56, 189, 248, 0.1);
      border-color: #38bdf8;
      color: #38bdf8;
      transform: scale(1.1);
    }

    .empty-state {
      text-align: center;
      padding: 4rem 2rem;
      background: rgba(30, 41, 59, 0.3);
      border: 2px dashed #334155;
      border-radius: 12px;
      margin: 2rem 0;
      grid-column: 1 / -1;
    }

    .empty-state-icon {
      font-size: 3rem;
      margin-bottom: 1rem;
      opacity: 0.5;
    }

    .empty-state-title {
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .empty-state-text {
      color: #94a3b8;
    }

    .pagination {
      display: flex;
      gap: 0.5rem;
      justify-content: center;
      margin: 3rem 0;
      flex-wrap: wrap;
    }

    .page-link {
      padding: 0.6rem 0.9rem;
      border-radius: 6px;
      border: 1px solid #334155;
      color: #cbd5e1;
      text-decoration: none;
      transition: all 0.2s ease;
      font-weight: 500;
      cursor: pointer;
      background: transparent;
    }

    .page-link:hover {
      background: rgba(56, 189, 248, 0.1);
      border-color: #38bdf8;
      color: #38bdf8;
      transform: translateY(-2px);
    }

    .page-link.active {
      background: linear-gradient(135deg, #38bdf8 0%, #0ea5e9 100%);
      border-color: #38bdf8;
      color: #0f172a;
      font-weight: 700;
    }

    @media (max-width: 1024px) {
      .users-grid {
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      }
    }

    @media (max-width: 768px) {
      .users-title {
        font-size: 1.8rem;
      }

      .filter-bar {
        flex-direction: column;
        gap: 1rem;
      }

      .search-container {
        min-width: 100%;
        flex: 1 0 100%;
      }

      .filter-controls {
        width: 100%;
        justify-content: flex-start;
      }

      .users-grid {
        grid-template-columns: 1fr;
      }

      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .user-stats {
        grid-template-columns: repeat(3, 1fr);
      }
    }