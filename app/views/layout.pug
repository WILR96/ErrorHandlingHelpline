doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title #{title || "Error Handling Helpline"}
    link(rel="stylesheet", href="/css/main.css")

  body
    .app
      aside.sidebar
        h2.logo Error Handling Helpline
        nav
          ul
            li
              a(class=active === "home" ? "active" : "", href="/") Home
            li
              a(class=active === "posts" ? "active" : "", href="/posts") Posts
            if categories
              each category in categories
                li
                  a(class=active == category.id ? "active" : "", href=`/posts?category=${category.id}`)= category.name
            li
              a(class=active === "leaderboards" ? "active" : "", href="/leaderboards") Leaderboards
            li
              a(class=active === "archives" ? "active" : "", href="/archives") Archives
            if !user   
              li
                a(class=active === "login" ? "active" : "", href="/login") Login
            else 
              li
                a(class=active === "logout" ? "active" : "", href="/logout") Logout

      main.content
        block content

      footer.footer
        p © #{new Date().getFullYear()} Error Handling Helpline