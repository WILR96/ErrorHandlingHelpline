extends layout

block content
  h1 Posts
  
  form(method="GET", action="/posts")
    select(name="category", onchange="this.form.submit()")
      option(value="") All Categories
      each category in categories
        option(
          value=category.id 
          selected=(selectedCategory == category.id)
        )= category.name
        
  ul
    each post in posts
          - const preview = post.content.length > 150 ? post.content.substring(0, 150) + "..." : post.content
          .post-card
            .post-header
              h3
                a(href=`/posts/${post.id}`)= post.title 
              if post.solved
                span.status.solved SOLVED
              else
                span.status.not-solved NOT SOLVED
            p= preview

            if post.comments && post.comments.length > 0
              .comments
                h4 Comments (#{post.comments.length})
                each comment in post.comments
                  .comment
                    .comment-row
                      img.avatar(src=`https://ui-avatars.com/api/?name=${comment.username}`)
                      p 
                        strong 
                          a(href=`/users/${comment.user_id}`)= `${comment.username} ⭐${comment.reputation}`
            else
              p No comments.. Share your thoughts!