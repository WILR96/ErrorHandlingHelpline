extends layout

block content
  .auth-container
    .auth-layout
      // Left Side - Branding
      .auth-side.side-brand
        .auth-branding
          .brand-icon 🚀
          h2.auth-title Error Handling Helpline
          p.auth-subtitle Reset your password and get back to helping the community

        .auth-features
          .feature-item
            .feature-icon 🔐
            .feature-text We'll send you a secure recovery link
          .feature-item
            .feature-icon ⏱️
            .feature-text Recovery link expires in 24 hours
          .feature-item
            .feature-icon ✅
            .feature-text Create a new strong password

      // Right Side - Form
      .auth-side.side-form
        .auth-form
          h2.auth-title Forgot Password?
          p.auth-subtitle Enter your email to receive a password recovery link

          if success
            .alert.alert-success
              span.alert-icon ✓
              span.alert-message= success
              button.alert-close(type="button") ✕

          if error
            .alert.alert-error
              span.alert-icon ⚠️
              span.alert-message= error
              button.alert-close(type="button") ✕

          form(method="POST" action="/forgot-password")
            .auth-form-group
              label.form-label Email Address
              input.form-input(type="email" name="email" placeholder="your@email.com" required)
              p.form-hint Enter the email associated with your account

            button.btn.btn-primary.btn-block(type="submit")
              | Send Recovery Link

          .auth-divider
            span or

          .auth-footer
            | Remember your password?
            a(href="/login") Login here

          .auth-footer(style="margin-top: 1rem;")
            a(href="/sign-up") Don't have an account? Sign up

    script.
      document.querySelector('.alert-close')?.addEventListener('click', function() {
        this.parentElement.style.display = 'none';
      });
